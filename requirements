# ==================================================================
# Air Mouse Superior Pro  – Requirements
# ==================================================================
# Install with: pip install -r requirements.txt
# For optional features, uncomment the relevant lines below.
# ==================================================================

# -------------------- Core Dependencies (Required) --------------------
mediapipe>=0.10.0          # Hand landmark detection
opencv-python>=4.8.0       # Camera capture & image processing
numpy>=1.24.0              # Numerical operations
pyautogui>=0.9.54          # Universal mouse control fallback

# -------------------- Windows Native Mouse (Recommended) --------------
pywin32>=306               # Low-latency Windows mouse backend

# -------------------- Platform‑Specific (Optional) --------------------
# macOS native mouse backend
# pyobjc-framework-Quartz>=9.0

# Linux native mouse backend
# evdev>=1.6.0

# -------------------- Multi‑Monitor Support (Optional) ----------------
# screeninfo>=0.8.1

# -------------------- System Tray Icon (Optional) --------------------
# pystray>=0.19.0
# Pillow>=10.0.0

# -------------------- REST API Server (Optional) ----------------------
# flask>=3.0.0

# -------------------- Audio Feedback (Optional) -----------------------
# Windows uses built-in winsound; for Linux/macOS:
# playsound>=1.3.0

# -------------------- Telemetry Backend (Optional) --------------------
# SQLite3 is built-in; no extra package required.

